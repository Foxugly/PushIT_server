# =============================================================================
# PushIT Server — Environment variables
#
# DEV:  copy to .env and use as-is
# PROD: adapt values below or use GitHub Secret DOTENV_PROD
# =============================================================================

# --- Django core ---
DJANGO_SECRET_KEY=django-insecure-change-me
STATE=DEV
# STATE=PROD
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
CSRF_TRUSTED_ORIGINS=

# --- Database ---
DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=
DATABASE_HOST=
DATABASE_PORT=
DATABASE_USER=
DATABASE_PASSWORD=

# --- Media ---
MEDIA_ROOT_DIR=media

# --- Redis / Celery ---
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
CELERY_TASK_DEFAULT_QUEUE=celery

# --- JWT ---
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

# --- Firebase Cloud Messaging ---
FCM_SERVICE_ACCOUNT_PATH=

# --- Microsoft Graph API (inbox polling + outbound replies) ---
# These are kept for READING the shared mailbox via Graph API.
# Alias management has moved to PowerShell (see Exchange Online section below).
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_MAILBOX_USER_ID=
INBOUND_EMAIL_DOMAIN=pushit.com

# --- Exchange Online alias management (PowerShell Core + ExchangeOnlineManagement) ---
# See exchange/README.md for full setup (Azure AD app, certificate, role assignment).
#
# Path to the PowerShell script (defaults to scripts/exchange/manage_alias.ps1).
EXCHANGE_PS_SCRIPT_PATH=
# Azure AD application (client) ID of the service principal used for app-only auth.
EXCHANGE_APP_ID=
# Tenant primary DOMAIN (e.g. contoso.onmicrosoft.com) — NOT the Directory ID GUID.
EXCHANGE_TENANT=
# Authentication: pick ONE of the two modes below.
#   1) Thumbprint of a certificate in PowerShell's cert store. WINDOWS ONLY.
#      Leave EMPTY on Linux — Connect-ExchangeOnline does not expose this
#      parameter on Linux pwsh, and if both this and EXCHANGE_CERT_FILE_PATH
#      are set, the script picks the thumbprint and the connection fails.
EXCHANGE_CERT_THUMBPRINT=
#   2) Path to a PFX/PEM file (with optional password). REQUIRED on Linux.
EXCHANGE_CERT_FILE_PATH=/etc/pushit/pushit-exchange.pfx
EXCHANGE_CERT_PASSWORD=
# Primary SMTP address of the shared mailbox that hosts the inbound aliases.
EXCHANGE_SHARED_MAILBOX=
# Subprocess timeout for each pwsh invocation, in seconds.
EXCHANGE_PS_TIMEOUT=60

# --- Observability ---
METRICS_AUTH_TOKEN=
